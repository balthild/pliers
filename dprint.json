{
	"includes": [
		".vscode/*.json",
		".swift-format",
		"dprint.json",
		"Resources/**/*.{js,css}",
		"Public/js/*.js",
		"Sources/PliersSystemd/*.xml",
		"Sources/**/*.swift",
		"Package.swift",
	],
	"excludes": [
		".build",
	],
	"useTabs": true,
	"indentWidth": 2,
	"lineWidth": 100,
	"oxc": {
		"quoteStyle": "single",
		"quoteProperties": "consistent",
		"experimentalSortImports": {
			"groups": [
				["style", "side_effect_style"],
				["builtin"],
				["external"],
				["internal", "subpath"],
				["parent", "sibling", "index"],
				["unknown"],
			],
		},
	},
	"markup": {
		"associations": ["*.{html,svg,xml}"],
		"styleIndent": true,
		"scriptIndent": true,
		"scriptFormatter": "biome",
		"html.void.selfClosing": true,
		"component.selfClosing": true,
	},
	"malva": {
		"quotes": "preferSingle",
	},
	"json": {
		"associations": ["*.{json,jsonc}", ".swift-format"],
		"trailingCommas": "jsonc",
		"jsonTrailingCommaFiles": [
			"dprint.json",
			".vscode/extensions.json",
			".vscode/launch.json",
			".vscode/settings.json",
		],
	},
	"exec": {
		"cwd": "${configDir}",
		"commands": [
			{
				"command": "swift-format {{file_path}}",
				"exts": ["swift"],
				"cacheKeyFiles": [".swift-format"],
				"stdin": false,
			},
		],
	},
	"plugins": [
		"https://plugins.dprint.dev/oxc-0.28.0.wasm",
		"https://plugins.dprint.dev/json-0.22.0.wasm",
		"https://plugins.dprint.dev/g-plane/markup_fmt-v0.27.3.wasm",
		"https://plugins.dprint.dev/g-plane/malva-v0.16.0.wasm",
		"https://plugins.dprint.dev/exec-0.7.2.json",
	],
}
